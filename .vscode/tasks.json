{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Chạy Streamlit",
            "type": "shell",
            "command": "python",
            "args": [
                "-m", "streamlit", "run", "app.py",
                "--server.port", "8501"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "fullstack"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*",
                    "endsPattern": ".*Local URL.*|.*started.*"
                }
            }
        },
        {
            "label": "Chạy FastAPI",
            "type": "shell",
            "command": "python",
            "args": [
                "-m", "uvicorn", "backend.api:app",
                "--reload",
                "--host", "0.0.0.0",
                "--port", "8000"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "fullstack"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*",
                    "endsPattern": ".*Application startup complete.*"
                }
            }
        },
        {
            "label": "🔥 Full Stack",
            "dependsOn": [
                "Chạy FastAPI",
                "Chạy Streamlit"
            ],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
